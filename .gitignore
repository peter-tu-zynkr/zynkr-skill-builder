# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# production
/build
back-end/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!**/.env.example

# python caches / local tooling
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/

# local tokens / debug artifacts
.mcpregistry_github_token
.mcpregistry_registry_token
*.jsonl
*.log

# typescript
*.tsbuildinfo
next-env.d.ts

# internal docs — keep the public surface to README / architecture / taxonomy /
# the skills tree / the ingest scripts. Roadmap, process, and backlog stay local
# (mirrored in the private zynkr-skill-idea repo when useful).
plan.md
to-do.md
process.md
_private/
