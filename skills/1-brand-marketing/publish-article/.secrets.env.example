# publish-article — copy this file to `.secrets.env` (gitignored, chmod 600) and fill it in.
# Never paste these values into chat or commit them.
#
# 1. Create a Buffer API access token in Buffer → Developers (choose the longest expiry).
# 2. Run:  python3 scripts/buffer_post.py --list-channels   to print your org + channel IDs.
# 3. Paste the values below.

BUFFER_ACCESS_TOKEN=
BUFFER_ORG_ID=
BUFFER_CHANNEL_FACEBOOK=
BUFFER_CHANNEL_THREADS=
BUFFER_CHANNEL_INSTAGRAM=
